# Delta API — copy to .env and fill in.
# NEVER commit real values. ALL VARS HERE ARE SERVER-SIDE ONLY.

# Supabase
SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
SUPABASE_ANON_KEY=public-anon-key-safe-for-client
SUPABASE_SERVICE_ROLE_KEY=SERVER-ONLY-do-not-expose

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Intangles
INTANGLES_CLIENT_ID=
INTANGLES_CLIENT_SECRET=

# Postgres direct (Session Pooler over IPv4). For migrations + validation.
# Populate from Supabase Dashboard → Connect → Session pooler + IPv4 toggle.
# Password may contain # and / — keep "quoted" so dotenv doesn't treat as comment.
SUPABASE_DB_URL=postgresql://postgres.YOUR-REF:URL_ENCODED_PASSWORD@aws-1-us-east-1.pooler.supabase.com:5432/postgres
PGPASSWORD="raw password here"
PGHOST=aws-1-us-east-1.pooler.supabase.com
PGPORT=5432
PGUSER=postgres.YOUR-REF
PGDATABASE=postgres

# Runtime
NODE_ENV=development
PORT=4000
FRONTEND_ORIGIN=http://localhost:5173

# One-time bootstrap admin user (consumed by db/seed/bootstrap_admin.mjs).
# Safe to clear from .env after first successful run.
ADMIN_BOOTSTRAP_EMAIL=
ADMIN_BOOTSTRAP_PASSWORD=
ADMIN_BOOTSTRAP_FULL_NAME=
