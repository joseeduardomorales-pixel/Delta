# Delta API — copy to .env and fill in.
# NEVER commit real values. ALL VARS HERE ARE SERVER-SIDE ONLY.

# Supabase
SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
SUPABASE_ANON_KEY=public-anon-key-safe-for-client
SUPABASE_SERVICE_ROLE_KEY=SERVER-ONLY-do-not-expose

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Intangles
INTANGLES_CLIENT_ID=
INTANGLES_CLIENT_SECRET=

# Runtime
NODE_ENV=development
PORT=4000
FRONTEND_ORIGIN=http://localhost:5173
