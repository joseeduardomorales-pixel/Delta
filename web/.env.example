# Delta Web — copy to .env and fill in.
# VITE_* variables are bundled into the CLIENT. Never put a service
# role key, Anthropic key, or Intangles secret in this file.

VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=public-anon-key-safe-for-client
VITE_API_URL=http://localhost:4000
