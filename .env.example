# Delta — root .env.example
# Copy any package-specific values into web/.env and api/.env.
# NEVER commit real values. NEVER paste secrets into shared chats.

# ── Supabase (shared) ─────────────────────────────────────────────
SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
SUPABASE_ANON_KEY=public-anon-key-safe-for-client
SUPABASE_SERVICE_ROLE_KEY=SERVER-ONLY-do-not-expose

# ── Anthropic (server only) ───────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Intangles (server only) ───────────────────────────────────────
INTANGLES_CLIENT_ID=
INTANGLES_CLIENT_SECRET=

# ── Runtime ───────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
FRONTEND_ORIGIN=http://localhost:5173

# ── Frontend public env (Vite — bundled into the client) ──────────
VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=public-anon-key-safe-for-client
VITE_API_URL=http://localhost:4000
